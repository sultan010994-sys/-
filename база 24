<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Basis Pro: Hierarchy & Fragments</title>
    <style>
        body { margin: 0; overflow: hidden; font-family: 'Segoe UI', sans-serif; display: flex; background: #202020; color: white; }
        #viewer { flex-grow: 1; height: 100vh; }
        
        #sidebar { 
            width: 350px; height: 100vh; background: #2d2d2d; 
            border-left: 1px solid #444; padding: 15px; 
            overflow-y: auto; box-shadow: -5px 0 15px rgba(0,0,0,0.3);
        }

        h2 { font-size: 18px; margin-bottom: 20px; color: #00a8ff; border-bottom: 1px solid #444; padding-bottom: 10px; }

        /* Стили дерева */
        .tree-node { margin-left: 15px; user-select: none; }
        .tree-header { 
            display: flex; align-items: center; padding: 4px 8px; 
            cursor: pointer; border-radius: 4px; transition: 0.2s;
        }
        .tree-header:hover { background: #3d3d3d; }
        
        .toggle-icon { margin-right: 8px; font-size: 12px; width: 12px; display: inline-block; }
        .visibility-check { margin-right: 10px; cursor: pointer; width: 16px; height: 16px; }
        
        .node-name { font-size: 13px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .is-mesh { color: #ccc; }
        .is-group { color: #ffca28; font-weight: bold; }

        #loading-screen {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.8); display: flex; justify-content: center;
            align-items: center; z-index: 1000; font-size: 24px;
        }
    </style>
</head>
<body>

    <div id="loading-screen">Загрузка проекта из Базиса...</div>
    <div id="viewer"></div>
    
    <div id="sidebar">
        <h2>Структура изделия</h2>
        <div id="tree-container"></div>
    </div>

    <script type="importmap">
        {
            "imports": {
                "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
                "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/"
            }
        }
    </script>

    <script type="module">
        import * as THREE from 'three';
        import { OBJLoader } from 'three/addons/loaders/OBJLoader.js';
        import { MTLLoader } from 'three/addons/loaders/MTLLoader.js';
        import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

        // Названия твоих файлов
        const FILE_OBJ = 'model.obj'; 
        const FILE_MTL = 'model.mtl'; 

        const scene = new THREE.Scene();
        scene.background = new THREE.Color(0x1a1a1a);

        const camera = new THREE.PerspectiveCamera(45, (window.innerWidth - 350) / window.innerHeight, 1, 50000);
        camera.position.set(2000, 1500, 2000);

        const renderer = new THREE.WebGLRenderer({ antialias: true });
        renderer.setSize(window.innerWidth - 350, window.innerHeight);
        renderer.outputColorSpace = THREE.SRGBColorSpace;
        document.getElementById('viewer').appendChild(renderer.domElement);

        const controls = new OrbitControls(camera, renderer.domElement);
        controls.enableDamping = true;

        scene.add(new THREE.AmbientLight(0xffffff, 1.2));
        const light = new THREE.DirectionalLight(0xffffff, 0.8);
        light.position.set(5000, 5000, 5000);
        scene.add(light);

        // Функция построения дерева меню
        function createTreeUI(object, container) {
            const node = document.createElement('div');
            node.className = 'tree-node';

            const header = document.createElement('div');
            header.className = 'tree-header';

            // Чекбокс видимости
            const check = document.createElement('input');
            check.type = 'checkbox';
            check.className = 'visibility-check';
            check.checked = true;
            check.onclick = (e) => {
                e.stopPropagation();
                object.visible = check.checked;
            };

            const nameSpan = document.createElement('span');
            nameSpan.className = 'node-name ' + (object.children.length > 0 ? 'is-group' : 'is-mesh');
            nameSpan.textContent = object.name || (object.children.length > 0 ? "Группа" : "Деталь");

            header.appendChild(check);
            header.appendChild(nameSpan);
            node.appendChild(header);

            // Если есть дети, создаем вложенный контейнер
            if (object.children.length > 0) {
                const childContainer = document.createElement('div');
                childContainer.style.display = 'block';
                node.appendChild(childContainer);

                // Рекурсивно добавляем детей
                object.children.forEach(child => createTreeUI(child, childContainer));

                // Клик по заголовку сворачивает/разворачивает группу
                header.onclick = () => {
                    childContainer.style.display = childContainer.style.display === 'none' ? 'block' : 'none';
                };
            }

            container.appendChild(node);
        }

        // Загрузка
        const mtlLoader = new MTLLoader();
        mtlLoader.load(FILE_MTL, (materials) => {
            materials.preload();
            const objLoader = new OBJLoader();
            objLoader.setMaterials(materials);
            
            objLoader.load(FILE_OBJ, (object) => {
                document.getElementById('loading-screen').style.display = 'none';
                
                // Строим меню на основе иерархии OBJ
                const treeContainer = document.getElementById('tree-container');
                createTreeUI(object, treeContainer);

                // Центрирование
                const box = new THREE.Box3().setFromObject(object);
                const center = box.getCenter(new THREE.Vector3());
                object.position.sub(center);
                scene.add(object);
                
                controls.target.set(0, 0, 0);
                controls.update();
            });
        });

        function animate() {
            requestAnimationFrame(animate);
            controls.update();
            renderer.render(scene, camera);
        }
        animate();

        window.addEventListener('resize', () => {
            camera.aspect = (window.innerWidth - 350) / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth - 350, window.innerHeight);
        });
    </script>
</body>
</html>
